# Copy these names into Cloudflare Worker Variables and Secrets.
# Never put a real token in this example file or commit a populated .env file.

GHL_PRIVATE_INTEGRATION_TOKEN=replace_with_private_integration_token
GHL_LOCATION_ID=replace_with_sub_account_location_id
GHL_API_BASE=https://services.leadconnectorhq.com
GHL_API_VERSION=2021-07-28
WEDDING_ID=hart-brooks-2026
ALLOWED_ORIGIN=https://your-github-account.github.io
DEBUG_KEY=replace_with_a_long_random_debug_key
SEATING_SYNC_KEY=replace_with_a_long_random_seating_sync_key
SEATING_LOOKUP_ID_SECRET=replace_with_a_different_long_random_lookup_id_secret

# Create a Cloudflare Workers KV binding named SEATING_LOOKUP in the dashboard.
# KV bindings are runtime resources, not plaintext environment variables.
